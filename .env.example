# Copy to .env (gitignored) and fill in your key.

# OpenRouter API key — used by `owb judge` and `owb bench --auto-judge`.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional override for the judge model. Default: anthropic/claude-opus-4.7
# OPENROUTER_JUDGE_MODEL=anthropic/claude-opus-4.7
